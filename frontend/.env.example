# Frontend Environment Variables
# Copy this to .env.local and fill in the values

# Optional: direct API base URL (browser → FastAPI). Leave unset for local dev so requests
# go to same-origin /api/... and next.config.js rewrites proxy to BACKEND_URL (default http://127.0.0.1:8000).
# Setting NEXT_PUBLIC_API_URL=http://localhost:8000 breaks chat when the site is opened from another
# device (localhost then points at that device, not your PC).
# NEXT_PUBLIC_API_URL=

# Server-side only: where Next.js proxies /api (optional; auto on Vercel → https://<host>/_/backend)
# Local default: http://127.0.0.1:8000
# BACKEND_URL=http://127.0.0.1:8000
# Production override example:
# BACKEND_URL=https://lojj-liard.vercel.app/_/backend

# Optional: guest "Connect to front desk?" Yes button opens dialer (match HOTEL_FRONT_DESK_PHONE on backend)
# NEXT_PUBLIC_HOTEL_FRONT_DESK_PHONE=+15551234
