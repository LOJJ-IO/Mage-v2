# Leave NEXT_PUBLIC_API_URL unset so the browser uses same-origin /api/... (proxied to FastAPI).
# Only set it if the frontend must call the API host directly (no Next.js dev server).
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side proxy target (optional; default http://127.0.0.1:8000)
# BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_ALLOW_DEV_GUEST_LOGIN=true