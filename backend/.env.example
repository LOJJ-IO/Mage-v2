# Mage Backend Configuration

# App settings
DEBUG=true

# Supabase settings (optional for now - using mock database)
SUPABASE_URL=
SUPABASE_KEY=

# OpenRouter: API key and model IDs (any model from https://openrouter.ai/docs#models)
OPENROUTER_API_KEY=
# LLM_MODEL=
# LLM_MODEL_SMALL=
# LLM_MODEL_LARGE=

# Hotel context for small model (optional)
# HOTEL_NAME=Mage Hotel
# HOTEL_KNOWLEDGE_PATH=path/to/hotel_knowledge.md

# Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
