# Mage Backend Configuration

# App settings
DEBUG=true

# Supabase settings (optional for now - using mock database)
SUPABASE_URL=
SUPABASE_KEY=

# OpenRouter: API key and model (https://openrouter.ai/docs#models)
OPENROUTER_API_KEY=
# Use openrouter/auto to let OpenRouter pick the model (https://openrouter.ai/docs/guides/routing/routers/auto-router)
# LLM_MODEL=openrouter/auto
# LLM_MODEL_SMALL=openrouter/auto
# LLM_MODEL_LARGE=openrouter/auto
# Optional: restrict Auto Router to patterns, e.g. LLM_AUTO_ALLOWED_MODELS=google/*,meta-llama/*
# LLM_AUTO_ALLOWED_MODELS=
# Fallbacks when primary returns 404
# LLM_MODEL_FALLBACKS=google/gemini-2.0-flash-exp:free,google/gemini-flash-1.5:free
# Default: OpenRouter routers (free pool + auto). Optional caps reduce thinking-model length failures.
# LLM_MODEL_SMALL=openrouter/free
# LLM_MODEL_LARGE=openrouter/auto
# LLM_MODEL_FALLBACKS=openrouter/auto,openrouter/free
# LLM_MAX_TOKENS_SMALL=512
# LLM_MAX_TOKENS_LARGE=1024
# Optional: steer auto router away from slow thinking models, e.g. LLM_AUTO_ALLOWED_MODELS=google/*,meta-llama/*
# Small-model system prompt: short by default in code (_SMALL_MODEL_SYSTEM_SHORT). Say "revert the system prompt" to restore legacy.

# Two-layer routing (classifier JSON + copy writer prose; default on)
# LLM_USE_TWO_LAYER_ROUTING=true
# LLM_CLASSIFIER_MODELS=openrouter/free,openrouter/auto
# Pin classifier for OpenRouter prompt caching (required; not supported on openrouter/free|auto)
LLM_MODEL_CLASSIFIER=google/gemini-2.5-flash-lite
# CLASSIFIER_PROMPT_PATH=prompts/classifier.txt
LLM_CLASSIFIER_PROMPT_CACHE=true
# LLM_COPY_MODEL=openrouter/free
# LLM_MAX_TOKENS_CLASSIFIER=380
# LLM_MAX_TOKENS_COPY=400
# LLM_CLASSIFIER_MIN_CONFIDENCE=0.39
# LLM_CLASSIFIER_HISTORY_TURNS=2
# Skip resolved models that break JSON (LFM2.5 copies 0.0 confidence; GPT-5 Nano hits 64-tok length)
# LLM_CLASSIFIER_DISQUALIFIED_MODELS=lfm-2.5,lfm2.5,liquid/lfm,gpt-5-nano,openai/gpt-5-nano,nemotron-nano-9b-v2,nemotron-nano,nvidia/nemotron
# Copy writer uses classifier JSON + short gist (not full chat replay). Set true to restore full history.
# LLM_COPY_INCLUDE_FULL_HISTORY=false
# Optional: restrict classifier auto-router tier, e.g. LLM_AUTO_ALLOWED_MODELS=google/*,meta-llama/*

# Speech-to-text (Vercel: use openai + OPENAI_API_KEY; local dev: pip install -r requirements-local.txt)
# TRANSCRIPTION_PROVIDER=auto
# OPENAI_API_KEY=
# OPENAI_TRANSCRIPTION_MODEL=whisper-1
# WHISPER_MODEL_SIZE=tiny

# Hotel context for small model (optional)
# HOTEL_NAME=The Grand Horizon Hotel
# HOTEL_KNOWLEDGE_PATH=data/hotel_knowledge.md

# Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Staff inbox (used by /staff UI via X-Staff-Key header)
STAFF_ACCESS_KEY=mage-staff-dev

# Optional E.164 or local format for guest "call front desk" from chat confirmation
# HOTEL_FRONT_DESK_PHONE=+15551234

# Optional: Google Places API key for hotel knowledge pre-enrichment
# Enable: Google Places API in your Google Cloud project.
# GOOGLE_PLACES_API_KEY=

# Optional: dedicated model for task replies (defaults to LLM_MODEL_LARGE if unset)
# LLM_MODEL_THINKING=
